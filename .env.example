# === 模型 API Keys ===
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# === 模型配置 ===
FAST_MODEL=gpt-4o-mini
SLOW_MODEL=gpt-4o
COMPRESSOR_MODEL=gpt-4o-mini

# === 路由配置 ===
ROUTER_CONFIDENCE_THRESHOLD=0.75
QUALITY_GATE_ENABLED=true
FALLBACK_ENABLED=true

# === 数据库 ===
DATABASE_URL=postgresql://postgres:postgres@db:5432/smartrouter
REDIS_URL=redis://redis:6379

# === 服务端口 ===
BACKEND_PORT=3001
FRONTEND_PORT=3000

# === C3a + Sprint 48: Server Identity & JWT Auth ===
# Sprint 48: JWT Authentication (replaces X-User-Id as production auth)
# Production: MUST set JWT_SECRET (min 32 chars), JWT_ENABLED=true, ALLOW_DEV_FALLBACK=false
JWT_SECRET=                          # REQUIRED in production: min 32-char secret
JWT_ENABLED=true                     # Enable JWT Bearer token auth (default: true)
JWT_EXPIRES_IN=86400                 # Token expiry in seconds (default: 24h)
# Sprint 48: User credentials (format: user:pass,user2:pass2)
# Default dev credentials: admin:changeme
AUTH_USERS=admin:changeme
# Legacy dev fallback: Set true only in local dev; production must provide JWT
ALLOW_DEV_FALLBACK=true

# === W1: Web Search ===
# Supported APIs: Serper (https://serper.dev), SerpAPI, Google Custom Search, etc.
# The endpoint must accept GET requests with ?q= and ?num= query params and return { results: [...] }
WEB_SEARCH_ENDPOINT=https://google.serper.dev/search
WEB_SEARCH_API_KEY=your-serper-api-key
WEB_SEARCH_MAX_RESULTS=5

# === Sprint 45: Phase 5 Storage Backend ===
# 存储后端选择：local | s3 | pg
# - local: 本地文件系统，数据主权/离线场景
# - s3: S3 兼容存储（AWS S3 / MinIO / Cloudflare R2）
# - pg: PostgreSQL（默认，支持语义搜索）
STORAGE_BACKEND=pg
# Phase 5 侧通道写入：设为 true 时，DelegationArchiveRepo 同时写入 IArchiveStorage
# 用途：本地文件/S3 备份 + 人工可读的 JSON 审查格式
USE_PHASE5_ARCHIVE=false
LOCAL_ARCHIVE_PATH=./data/archive
LOCAL_ARCHIVE_COMPRESS=false

# S3 配置（STORAGE_BACKEND=s3 时使用）
S3_BUCKET=smartrouter-archives
S3_REGION=us-east-1
S3_ENDPOINT=                 # MinIO: http://localhost:9000, R2: https://xxx.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PREFIX=archives/          # 前缀路径
ARCHIVE_TTL_DAYS=0           # 0 = 不过期，否则 N 天后自动清理（TTL eviction）

# === Phase 4: Local Trust Gateway (Sprint 40-43) ===
# Master switch — 开启后启用数据分类 + 权限层 + 脱敏引擎
USE_PERMISSION_LAYER=true
# 启用 Rule-based 数据分类器（基于数据类型/敏感级别/PII 检测）
USE_DATA_CLASSIFICATION=true
# 启用脱敏引擎（对 task_brief/worker_hint 中的敏感信息做 mask/replace/truncate）
USE_REDACTION=true
# 启用小模型输出守卫（检测提示注入/越狱/异常模式）
USE_SMALL_MODEL_GUARD=true

# === Phase D: LLM-Native Routing v2 ===
# 启用 LLM-Native 委托路由（Fast 模型自主判断是否委托 Slow）
USE_LLM_NATIVE_ROUTING=true
# 启用 Execution Loop（TaskPlanner + ExecutionLoop，body.execute=true 触发）
EXECUTION_RESULT_INJECTION_ENABLED=true
# 记忆检索策略：v1=重要性+新鲜度，v2=分类感知评分管道
MEMORY_RETRIEVAL_STRATEGY=v2

# === Sprint 25 + 补充: Embedding (Vector Memory Retrieval) ===
# Optional: enables semantic memory retrieval via pgvector
# If not set, system falls back to keyword-based retrieval (Sprint 24 behavior)
EMBEDDING_PROVIDER=siliconflow    # openai | siliconflow
EMBEDDING_API_KEY=                # Defaults to OPENAI_API_KEY if empty
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# SiliconFlow 专用（embedding.ts 硬编码 URL，v1-3 后应迁移至此）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
